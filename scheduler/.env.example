# ---------------------------------------------------------------------------
# Self-hosted Calendly — environment variables
# ---------------------------------------------------------------------------
# M1 uses SQLite locally (no external DB required). Postgres can be swapped in
# later by changing the datasource provider in prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Company timezone used to interpret interviewer availability windows.
# Slots are stored in UTC and displayed in this zone by default.
COMPANY_TZ="Asia/Taipei"

# Public base URL of this app (used for building booking links later).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# The following are NOT used in M1 — they are placeholders for later milestones
# and intentionally left blank until credentials are provided.
# ---------------------------------------------------------------------------
# M2: Google OAuth + free/busy. When all four are set, the admin can connect
# each interviewer's Google calendar and slots will respect their real busy time.
# Leave them blank to keep M1 behaviour (weekly availability only).
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
# GOOGLE_TOKEN_ENC_KEY=""   # 32-byte key (base64) for encrypting refresh tokens; generate: openssl rand -base64 32
# GOOGLE_SCOPES=""          # optional; defaults to calendar.freebusy + calendar.events + userinfo.email

# M3: outbound mail (Gmail API or Workspace SMTP via recruit@)
# MAIL_FROM="recruit@cmoney.com.tw"

# M5: orchestration hub webhook (HMAC-signed)
# HUB_WEBHOOK_URL=""
# HUB_WEBHOOK_SECRET=""

# Admin login domain restriction (M-later)
# ALLOWED_GOOGLE_DOMAIN="cmoney.com.tw"
